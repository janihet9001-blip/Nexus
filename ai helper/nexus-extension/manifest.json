{
  "manifest_version": 3,
  "name": "NEXUS AI Assistant",
  "version": "2.0",
  "description": "Control your browser with voice or text. Open Claude with a prompt, play YouTube, set volume & brightness — all by speaking or typing.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "offscreen"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NEXUS AI (Ctrl+Shift+N)"
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+N",
        "mac":     "Command+Shift+N"
      },
      "description": "Open NEXUS command bar"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["config.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
