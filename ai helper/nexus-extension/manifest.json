{
  "manifest_version": 3,
  "name": "NEXUS AI Assistant",
  "version": "1.0",
  "description": "Your personal AI assistant in the browser. Open tabs, search, play YouTube, ask questions — all by typing.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NEXUS AI (Ctrl+Shift+N)"
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+N",
        "mac":     "Command+Shift+N"
      },
      "description": "Open NEXUS command bar"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
  ,
"web_accessible_resources": [
  {
    "resources": ["config.js"],
    "matches": ["<all_urls>"]
  }
]
}
